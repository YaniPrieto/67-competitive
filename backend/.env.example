PORT=5000
NODE_ENV=development
DATABASE_PATH=./data/gesture-battle.db

# Public frontend URL allowed to call this backend.
# For production, set this to your Vercel URL.
# CLIENT_ORIGIN=https://your-game.vercel.app
#
# Optional comma-separated list for preview/custom domains.
# CLIENT_ORIGINS=https://your-game.vercel.app,https://www.yourdomain.com

# Optional for mobile LAN camera testing with HTTPS/WSS:
# SSL_KEY_FILE=../certs/192.168.1.25-key.pem
# SSL_CRT_FILE=../certs/192.168.1.25.pem
